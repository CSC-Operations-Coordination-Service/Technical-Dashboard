            "file_pattern": "*log*txt",
            "model": "S3PMetrics",
            "extractor": {
                "class": "LogExtractor",
                "args": {
                    "pattern": "(?P<month>\\w{3})\\s+(?P<day>\\d{1,2})\\s+(?P<time>\\d{2}:\\d{2}:\\d{2})\\s+(?P<hostname>\\S+)\\s+(?P<process>\\w+)\\[(?P<pid>\\d+)\\]:\\s*M&C\\|Timeliness\\|TL\\|OUT\\|eventtime=\"(?P<eventtime>[^\"]+)\"\\|eventname=\"(?P<eventname>[^\"]+)\"\\|check=\"(?P<check>[^\"]+)\"\\|timelinessKey=\"(?P<timelinessKey>[^\"]+)\"\\|filename=\"(?P<filename>[^\"]+)\"\\|pmode=\"(?P<pmode>[^\"]+)\"\\|validitystart=\"(?P<validitystart>[^\"]+)\"\\|validitystop=\"(?P<validitystop>[^\"]+)\"\\|generationtime=\"(?P<generationtime>[^\"]+)\"\\|env=\"(?P<env>[^\"]+)\"\\|ptype=\"(?P<ptype>[^\"]+)\"\\|level=\"(?P<level>[^\"]+)\"\\|sat=\"(?P<sat>[^\"]+)\"\\|message=\"(?P<message>[^\"]*)\"\\|?reftime=\"(?P<reftime>[^\"]+)\"\\|?"
                }
            }
